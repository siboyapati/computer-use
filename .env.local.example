# Anthropic — get from https://console.anthropic.com (billing enabled)
ANTHROPIC_API_KEY=sk-ant-...

# Steel.dev — get from https://app.steel.dev (free tier: 100 browser-hours)
STEEL_API_KEY=ste_...

# Optional: override default Steel API base (leave empty for production)
# STEEL_BASE_URL=https://api.steel.dev

# Claude models — keep these in sync with src/lib/agent/runner.ts
ANTHROPIC_MODEL_DEFAULT=claude-haiku-4-5
ANTHROPIC_MODEL_HARD=claude-sonnet-4-6

# Google Gemini — optional, only required if you want the Gemini toggle in the UI
# Get from https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=
# Stagehand-compatible Gemini model id; gemini-3-flash-preview is the demo default
GEMINI_MODEL=gemini-3-flash-preview
